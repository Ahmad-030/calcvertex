<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.CalcVertex" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:navigationBarColor">@color/colorSurface</item>
        <item name="actionBarStyle">@style/CalcVertexActionBar</item>
        <item name="android:textColorPrimary">@color/colorTextPrimary</item>
        <item name="android:textColorSecondary">@color/colorTextSecondary</item>
    </style>

    <style name="CalcVertexActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/colorSurface</item>
        <item name="titleTextStyle">@style/CalcVertexActionBarTitle</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="CalcVertexActionBarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/colorTextPrimary</item>
        <item name="android:textSize">17sp</item>
    </style>

    <style name="Theme.CalcVertex.Splash" parent="Theme.CalcVertex">
        <item name="android:windowFullscreen">true</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/colorTeal</item>
        <item name="android:textColor">@color/colorBackground</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textStyle">bold</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="OutlineButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/colorTeal</item>
        <item name="android:textColor">@color/colorTeal</item>
        <item name="cornerRadius">14dp</item>
        <item name="strokeWidth">1dp</item>
    </style>

</resources>
