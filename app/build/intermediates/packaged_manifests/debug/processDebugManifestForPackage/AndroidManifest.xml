<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.burgaynet.calcvertex"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="24"
        android:targetSdkVersion="36" />

    <permission
        android:name="com.burgaynet.calcvertex.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.burgaynet.calcvertex.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.CalcVertex" >
        <activity
            android:name="com.burgaynet.calcvertex.activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.CalcVertex.Splash" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.burgaynet.calcvertex.activities.HomeActivity"
            android:exported="false" />
        <activity
            android:name="com.burgaynet.calcvertex.activities.FinanceActivity"
            android:exported="false" />
        <activity
            android:name="com.burgaynet.calcvertex.activities.HealthActivity"
            android:exported="false" />
        <activity
            android:name="com.burgaynet.calcvertex.activities.MathActivity"
            android:exported="false" />
        <activity
            android:name="com.burgaynet.calcvertex.activities.EverydayActivity"
            android:exported="false" />
        <activity
            android:name="com.burgaynet.calcvertex.activities.HistoryActivity"
            android:exported="false" />
        <activity
            android:name="com.burgaynet.calcvertex.activities.AboutActivity"
            android:exported="false" />

        <!-- Finance calcs -->
        <activity
            android:name="com.burgaynet.calcvertex.activities.EmiCalcActivity"
            android:exported="false" />
        <activity
            android:name="com.burgaynet.calcvertex.activities.ProfitLossActivity"
            android:exported="false" />
        <activity
            android:name="com.burgaynet.calcvertex.activities.GstCalcActivity"
            android:exported="false" />
        <activity
            android:name="com.burgaynet.calcvertex.activities.InterestCalcActivity"
            android:exported="false" />
        <activity
            android:name="com.burgaynet.calcvertex.activities.CurrencyCalcActivity"
            android:exported="false" />

        <!-- Health calcs -->
        <activity
            android:name="com.burgaynet.calcvertex.activities.BmiCalcActivity"
            android:exported="false" />
        <activity
            android:name="com.burgaynet.calcvertex.activities.CalorieCalcActivity"
            android:exported="false" />
        <activity
            android:name="com.burgaynet.calcvertex.activities.WaterCalcActivity"
            android:exported="false" />

        <!-- Math calcs -->
        <activity
            android:name="com.burgaynet.calcvertex.activities.AreaCalcActivity"
            android:exported="false" />
        <activity
            android:name="com.burgaynet.calcvertex.activities.PercentCalcActivity"
            android:exported="false" />
        <activity
            android:name="com.burgaynet.calcvertex.activities.BaseConverterActivity"
            android:exported="false" />

        <!-- Everyday calcs -->
        <activity
            android:name="com.burgaynet.calcvertex.activities.AgeCalcActivity"
            android:exported="false" />
        <activity
            android:name="com.burgaynet.calcvertex.activities.DateDiffActivity"
            android:exported="false" />
        <activity
            android:name="com.burgaynet.calcvertex.activities.UnitConverterActivity"
            android:exported="false" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.burgaynet.calcvertex.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>