<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <include layout="@layout/toolbar" />

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:id="@+id/calcContainer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp" app:cardElevation="0dp"
                app:cardBackgroundColor="@color/colorCard"
                app:strokeColor="@color/colorCardStroke" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                    <TextView android:id="@+id/tvCalcEmoji" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="📅" android:textSize="32sp"
                        android:layout_marginEnd="14dp"/>
                    <TextView android:id="@+id/tvCalcTitle" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Date Calc"
                        android:textSize="20sp" android:textStyle="bold" android:textColor="@color/colorTeal"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp" app:cardElevation="0dp"
                app:cardBackgroundColor="@color/colorCard"
                app:strokeColor="@color/colorCardStroke" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">

                    <TextView android:id="@+id/tvDateLabel1"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Date 1" android:textSize="11sp"
                        android:textColor="@color/colorTextSecondary"
                        android:textAllCaps="true" android:letterSpacing="0.08"
                        android:layout_marginBottom="6dp"/>
                    <TextView android:id="@+id/tvDate1"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:background="@drawable/date_field_bg"
                        android:paddingStart="14dp" android:paddingEnd="14dp"
                        android:gravity="center_vertical"
                        android:textColor="@color/colorTextPrimary" android:textSize="15sp"
                        android:layout_marginBottom="16dp"
                        android:clickable="true" android:focusable="true"
                        android:drawableEnd="@android:drawable/ic_menu_today"
                        android:drawableTint="@color/colorTeal"/>

                    <LinearLayout android:id="@+id/date2Row"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <TextView android:id="@+id/tvDateLabel2"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Date 2" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary"
                            android:textAllCaps="true" android:letterSpacing="0.08"
                            android:layout_marginBottom="6dp"/>
                        <TextView android:id="@+id/tvDate2"
                            android:layout_width="match_parent" android:layout_height="52dp"
                            android:background="@drawable/date_field_bg"
                            android:paddingStart="14dp" android:paddingEnd="14dp"
                            android:gravity="center_vertical"
                            android:textColor="@color/colorTextPrimary" android:textSize="15sp"
                            android:clickable="true" android:focusable="true"
                            android:drawableEnd="@android:drawable/ic_menu_today"
                            android:drawableTint="@color/colorTeal"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp" app:cardElevation="0dp"
                app:cardBackgroundColor="@color/colorCard"
                app:strokeColor="@color/colorCardStroke" app:strokeWidth="1dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Result" android:textSize="11sp"
                            android:textColor="@color/colorTextSecondary"
                            android:textAllCaps="true" android:letterSpacing="0.08"/>
                        <TextView android:id="@+id/btnCopy"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📋 Copy" android:textSize="12sp"
                            android:textColor="@color/colorTeal" android:textStyle="bold"
                            android:clickable="true" android:focusable="true"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tvResult"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="—" android:textSize="17sp" android:textColor="@color/colorTeal"
                        android:fontFamily="monospace" android:background="@drawable/result_box_bg"
                        android:padding="16dp" android:minHeight="64dp" android:gravity="center"
                        android:lineSpacingMultiplier="1.5" android:textIsSelectable="true"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton android:id="@+id/btnClear"
                    style="@style/OutlineButton"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="1" android:layout_marginEnd="10dp"
                    android:text="Clear" android:textSize="14sp"/>
                <com.google.android.material.button.MaterialButton android:id="@+id/btnCalculate"
                    style="@style/PrimaryButton"
                    android:layout_width="0dp" android:layout_height="52dp"
                    android:layout_weight="2" android:text="Calculate" android:textSize="15sp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
